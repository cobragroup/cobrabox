# Python bytecode / caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Conda local env folders (if created in repo)
.conda/

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Build / packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# Negate global gitignore exclusions
!CLAUDE.md
!agents.md
!.claude/
!.claude/**
.claude/**/.DS_Store
.claude/.DS_Store

# Local data outputs (keep README placeholders)
data/raw/*
!data/raw/README.md
data/processed/*
!data/processed/README.md
data/synthetic/*
!data/synthetic/README.md
